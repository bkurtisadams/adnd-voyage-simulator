<form id="voyage-setup-form">
  <nav class="tabs" data-group="voyageSetupTabs">
    <a class="item" data-tab="voyage-details">Voyage Details</a>
    <a class="item" data-tab="crew-roster">Crew Roster</a>
  </nav>

  <section class="sheet-body">
    <!-- ============ VOYAGE DETAILS ============ -->
    <div class="tab" data-tab="voyage-details" data-group="voyageSetupTabs">
      
      <div class="form-group">
        <label for="mode">Simulation Mode:</label>
        <select id="mode" name="mode">
          <option value="auto" {{selected saved.mode "auto"}}>Automated (Instant Result)</option>
          <option value="manual" {{selected saved.mode "manual"}}>Manual (Day-by-Day)</option>
        </select>
        <p class="notes" style="font-size: 0.8em; color: #666;">Manual mode prepares the voyage state but requires you to advance days manually using the macro.</p>
      </div>

      <div class="form-group">
        <label for="shipID">Select Ship:</label>
        <select id="shipID" name="shipID" required>
          <option value="">-- Choose Ship --</option>
          {{#if namedShips.length}}
          <optgroup label="Your Ships">
            {{#each namedShips}}
              <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}} ({{this.shipType}})</option>
            {{/each}}
          </optgroup>
          {{/if}}
          <optgroup label="DMG Ships">
            {{#each templatesDMG}}
              <option value="tmpl:{{this.id}}">{{this.shipType}} — Hull {{this.hullFormula}}, {{this.cargoCapacity}} cargo, {{this.normalSail}} mph sail ({{this.cost}} gp)</option>
            {{/each}}
          </optgroup>
          <optgroup label="Seafaring Ships">
            {{#each templatesSeafaring}}
              <option value="tmpl:{{this.id}}">{{this.shipType}} — Hull {{this.hullFormula}}, {{this.cargoCapacity}} cargo, {{this.dailySail}} mi/day ({{this.cost}} gp)</option>
            {{/each}}
          </optgroup>
        </select>
      </div>

      <div class="form-group">
        <label for="routeID">Select Trade Route:</label>
        <select id="routeID" name="routeID" required>
          <option value="">-- Choose Route --</option>
          {{#each routes}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="startingGold">Starting Gold (gp):</label>
        <input type="number" id="startingGold" name="startingGold" value="{{saved.startingGold}}" min="0" required />
      </div>

      <hr/>

      <div class="form-group">
        <label>
          <input type="checkbox" id="automateTrading" name="automateTrading" {{#if saved.automateTrading}}checked{{/if}} />
          Automate Cargo Trading
        </label>
      </div>

      <div class="form-group" id="manualTradeModeGroup"
           style="display: {{#if saved.automateTrading}}none{{else}}block{{/if}};">
        <label>Trade Mode:</label><br/>
        <label>
          <input type="radio" name="tradeMode" value="speculation" {{#if (eq saved.tradeMode "speculation")}}checked{{/if}} />
          Speculation
        </label><br/>
        <label>
          <input type="radio" name="tradeMode" value="consignment" {{#if (eq saved.tradeMode "consignment")}}checked{{/if}} />
          Consignment
        </label>
      </div>

      <div class="form-group" id="commissionRateGroup"
           style="display:
             {{#if saved.automateTrading}}
               none
             {{else}}
               {{#if (eq saved.tradeMode "consignment")}}block{{else}}none{{/if}}
             {{/if}};">
        <label for="commissionRate">Commission Rate (%):</label>
        <input type="number" id="commissionRate" name="commissionRate" value="{{saved.commissionRate}}" min="10" max="40" />
      </div>

      <hr/>

      <div class="form-group">
        <label for="crewQuality">Crew Quality:</label>
        <select id="crewQuality" name="crewQuality">
          {{#each crewQualities}}
            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" id="enableRowing" name="enableRowing" {{#if saved.enableRowing}}checked{{/if}} />
          Enable Rowing (if applicable)
        </label>
      </div>

      <div class="form-group">
        <label for="latitude">Latitude (N):</label>
        <input type="number" id="latitude" name="latitude" value="{{saved.latitude}}" step="0.1" required/>
      </div>

      <div class="form-group">
        <label for="longitude">Longitude (E):</label>
        <input type="number" id="longitude" name="longitude" value="{{saved.longitude}}" step="0.1" required/>
      </div>

      <div class="form-group">
        <label for="startingYear">Starting Year (CY):</label>
        <input type="number" id="startingYear" name="startingYear" value="{{saved.startingYear}}" min="1" required/>
      </div>

      <div class="form-group">
        <label for="startingMonth">Starting Month:</label>
        <select id="startingMonth" name="startingMonth" required>
          <option value="">-- Choose Month --</option>
          {{#each months}}
            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.value}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="startingDay">Starting Day:</label>
        <input type="number" id="startingDay" name="startingDay" value="{{saved.startingDay}}" min="1" max="28" required/>
      </div>
    </div>

    <!-- ============ CREW ROSTER ============ -->
    <div class="tab" data-tab="crew-roster" data-group="voyageSetupTabs">
      <div class="crew-roster-header">
        <h2 style="margin:0">Ship's Officers</h2>
        <div class="crew-roster-actions">
          <select id="addOfficerRole">
            <option value="Captain">Captain</option>
            <option value="Lieutenant">Lieutenant</option>
            <option value="Mate">Mate</option>
            <option value="Navigator">Navigator</option>
            <option value="Artillerist">Artillerist</option>
            <option value="Surgeon">Surgeon</option>
          </select>
          <button type="button" class="add-officer-btn" title="Add Officer">
            <i class="fas fa-plus"></i> Add
          </button>
        </div>
      </div>

      <p><em>Officers loaded: {{officers.length}}</em></p>

      <div class="crew-roster-list" id="officerRoster">
        {{#each officers}}
        <div class="officer-card" data-index="{{@index}}">
          <div class="officer-summary">
            <span class="officer-role-badge role-{{this.roleLower}}">{{this.role}}</span>
            <input type="text" class="officer-name-input" name="officer_{{@index}}_name" value="{{this.name}}" placeholder="Name" />
            <span class="officer-level-display">Lv{{this.level}}</span>
            <span class="officer-skills-preview">
              {{#each this.skillTags}}<span class="skill-tag">{{this}}</span>{{/each}}
            </span>
            <button type="button" class="officer-btn officer-randomize" data-index="{{@index}}" title="Randomize">
              <i class="fas fa-dice"></i>
            </button>
            <button type="button" class="officer-btn officer-expand" data-index="{{@index}}" title="Details">
              <i class="fas fa-chevron-down"></i>
            </button>
            <button type="button" class="officer-btn officer-delete" data-index="{{@index}}" title="Remove">
              <i class="fas fa-times"></i>
            </button>
          </div>

          <div class="officer-detail" data-detail="{{@index}}" style="display:{{#if this.expanded}}block{{else}}none{{/if}};">
            <input type="hidden" name="officer_{{@index}}_role" value="{{this.role}}" />

            <div class="officer-detail-row">
              <label>Level <input type="number" name="officer_{{@index}}_level" value="{{this.level}}" min="0" max="20" /></label>
            </div>

            <div class="officer-abilities">
              <label>STR <input type="number" name="officer_{{@index}}_str" value="{{this.str}}" min="3" max="18" /></label>
              <label>DEX <input type="number" name="officer_{{@index}}_dex" value="{{this.dex}}" min="3" max="18" /></label>
              <label>CON <input type="number" name="officer_{{@index}}_con" value="{{this.con}}" min="3" max="18" /></label>
              <label>INT <input type="number" name="officer_{{@index}}_int" value="{{this.int}}" min="3" max="18" /></label>
              <label>WIS <input type="number" name="officer_{{@index}}_wis" value="{{this.wis}}" min="3" max="18" /></label>
              <label>CHA <input type="number" name="officer_{{@index}}_cha" value="{{this.cha}}" min="3" max="18" /></label>
            </div>

            <div class="officer-skills">
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_bargaining" {{#if this.skills.bargaining}}checked{{/if}} /> Bargaining</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_appraisal" {{#if this.skills.appraisal}}checked{{/if}} /> Appraisal</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_trade" {{#if this.skills.trade}}checked{{/if}} /> Trade</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_smuggling" {{#if this.skills.smuggling}}checked{{/if}} /> Smuggling</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_customsInspection" {{#if this.skills.customsInspection}}checked{{/if}} /> Customs Insp.</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_seamanship" {{#if this.skills.seamanship}}checked{{/if}} /> Seamanship</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_shipCarpentry" {{#if this.skills.shipCarpentry}}checked{{/if}} /> Ship Carpentry</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_navigation" {{#if this.skills.navigation}}checked{{/if}} /> Navigation</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_piloting" {{#if this.skills.piloting}}checked{{/if}} /> Piloting</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_seaLore" {{#if this.skills.seaLore}}checked{{/if}} /> Sea Lore</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_shipRowing" {{#if this.skills.shipRowing}}checked{{/if}} /> Ship Rowing</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_shipSailing" {{#if this.skills.shipSailing}}checked{{/if}} /> Ship Sailing</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_shipwright" {{#if this.skills.shipwright}}checked{{/if}} /> Shipwright</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_signaling" {{#if this.skills.signaling}}checked{{/if}} /> Signaling</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_vesselIdentification" {{#if this.skills.vesselIdentification}}checked{{/if}} /> Vessel ID</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_boating" {{#if this.skills.boating}}checked{{/if}} /> Boating</label>
              <label class="skill-check"><input type="checkbox" name="officer_{{@index}}_skill_artillerist" {{#if this.skills.artillerist}}checked{{/if}} /> Artillerist</label>
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      {{#unless officers}}
      <p class="no-officers"><em>No officers assigned. Add a Captain to begin.</em></p>
      {{/unless}}
    </div>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="button" class="dialog-button" data-button="cancel">Cancel</button>
    <button type="submit" class="dialog-button">Start Voyage</button>
  </footer>
</form>
